# Database
DB_USER=backend
DB_PASSWORD=LOL/A  # <-- 特殊字元現在可以直接使用
DB_HOST=db
DB_PORT=5432
DB_NAME=magic_pinecone_db

# Server URLs for OpenAPI Docs
GATEWAY_URL=http://localhost:18080
BACKEND_URL=http://localhost:8000

# Gemini API (RAG Preprocessing)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_LLM_MODEL=gemma-4-26B-A4B-it
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_LLM_RPM_LIMIT=15
GEMINI_EMBEDDING_RPM_LIMIT=100
GEMINI_MAX_EMBEDDINGS_PER_RUN=900

# NCU Portal OAuth
NCU_OAUTH_CLIENT_ID=your_client_id
NCU_OAUTH_CLIENT_SECRET=your_client_secret
NCU_OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback

# JWT Security
JWT_SECRET_KEY=generate_a_secure_random_string_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440



